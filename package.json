{
  "name": "aristo",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently \"next dev\" \"electron .\"",
    "start": "next build && electron .",
    "build": "next build && electron-builder",
    "server": "node start-server.js",
    "electron": "electron .",
    "frontend": "next dev"
  },
  "dependencies": {
    "@ai-sdk/react": "^1.0.0",
    "@radix-ui/react-collapsible": "^1.0.0",
    "@radix-ui/react-scroll-area": "^1.0.0",
    "@radix-ui/react-slot": "^1.0.0",
    "@streamdown/code": "^1.0.0",
    "ai": "^4.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "concurrently": "^8.0.0",
    "lucide-react": "^0.400.0",
    "mammoth": "^1.12.0",
    "next": "^14.0.0",
    "ollama-ai-provider": "^1.0.0",
    "pdf-parse": "^2.4.5",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "streamdown": "^2.0.0",
    "tailwind-merge": "^2.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "postcss": "^8.0.0",
    "tailwindcss": "^3.0.0"
  },
  "build": {
    "appId": "com.aristo",
    "productName": "Aristo",
    "compression": "store",
    "files": [
      "main.js",
      "api/**/*",
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/ollama",
        "to": "ollama"
      },
      {
        "from": "resources/models",
        "to": "models"
      },
      {
        "from": "resources/documents",
        "to": "documents"
      }
    ],
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    }
  }
}
