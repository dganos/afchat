{
  "name": "local-ai-docs",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently \"next dev\" \"electron .\"",
    "start": "next build && electron .",
    "build": "next build && electron-builder"
  },
  "dependencies": {
    "ai": "^4.0.0",
    "@ai-sdk/react": "^1.0.0",
    "ollama-ai-provider": "^1.0.0",
    "streamdown": "^2.0.0",
    "@streamdown/code": "^1.0.0",
    "zod": "^3.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "next": "^14.0.0",
    "concurrently": "^8.0.0",
    "clsx": "^2.0.0",
    "tailwind-merge": "^2.0.0",
    "class-variance-authority": "^0.7.0",
    "lucide-react": "^0.400.0",
    "@radix-ui/react-scroll-area": "^1.0.0",
    "@radix-ui/react-collapsible": "^1.0.0",
    "@radix-ui/react-slot": "^1.0.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "tailwindcss": "^3.0.0",
    "autoprefixer": "^10.0.0",
    "postcss": "^8.0.0"
  },
  "build": {
    "appId": "com.company.local-ai-docs",
    "productName": "Document Assistant",
    "files": [
      "main.js",
      "api/**/*",
      "out/**/*"
    ],
    "extraResources": [
      { "from": "resources/ollama", "to": "ollama" },
      { "from": "resources/models", "to": "models" },
      { "from": "resources/documents", "to": "documents" }
    ],
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    }
  }
}
